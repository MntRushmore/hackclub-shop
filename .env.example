GELATO_API_KEY=your_gelato_api_key_here
UPSTASH_REDIS_REST_URL=your_upstash_redis_rest_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token_here
HACKCLUB_CLIENT_ID=your_hackclub_client_id_here
HACKCLUB_CLIENT_SECRET=your_hackclub_client_secret_here
# Public base URL of the shop. Local dev: http://localhost:3000.
# Production: https://shop.hackclub.com
NEXTAUTH_URL=https://shop.hackclub.com
NEXTAUTH_SECRET=your_nextauth_secret_here
SLACK_BOT_TOKEN=your_slack_bot_token_here
# Stripe — the guest (cash) checkout. Customers pay by card on Stripe's hosted
# Checkout page; payment is confirmed ONLY by the signature-verified webhook.
STRIPE_SECRET_KEY=your_stripe_secret_key_here
# From the Stripe webhook endpoint (Dashboard → Developers → Webhooks). Required
# for /api/webhooks/stripe to verify event signatures.
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_signing_secret_here
# Sales tax. Set to 1/true once tax registrations + nexus are configured in the
# Stripe Dashboard — Checkout then computes sales tax (automatic_tax) and collects
# the customer's address. Leave blank/0 to ship without tax (e.g. before setup).
STRIPE_TAX_ENABLED=
# OPTIONAL test-mode key slot. When set, admins can flip checkout into Stripe
# test mode on /admin/finance — for themselves only, or for the whole store —
# and run end-to-end checkouts with Stripe test cards (orders are stamped
# isTest and excluded from stats/finance/donor wall). The test webhook secret
# comes from a SECOND webhook endpoint created in the Stripe test dashboard,
# pointing at the same /api/webhooks/stripe URL.
STRIPE_SECRET_KEY_TEST=
STRIPE_WEBHOOK_SECRET_TEST=
# Stripe Tax for the test slot (tax registrations are per-mode; leave blank
# unless you've enabled tax in the TEST dashboard too).
STRIPE_TAX_ENABLED_TEST=
# Vercel Cron auth — the reconcile-holds and match-followup crons refuse to run
# without it (Vercel sends it as `Authorization: Bearer <CRON_SECRET>`).
CRON_SECRET=
# OPTIONAL Google Places autocomplete on the checkout address form (typing aid
# only; EasyPost independently verifies deliverability server-side). Browser
# key from Google Cloud Console with Places API + Maps JavaScript API enabled,
# restricted to the shop's domains. Unset = plain text fields.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# HCB Donations — the PRIOR guest checkout, replaced by Stripe (HCB can't compute
# sales tax). Kept so admins can still reconcile/refund donation-era orders.
HCB_API_BASE=https://hcb.hackclub.com/api/v4
HCB_ORG_ID=your_hcb_org_id_here              # e.g. org_xxxxxx — for the transactions endpoint
HCB_ORG_SLUG=your_hcb_org_slug_here          # for the donation-start URL
HCB_CLIENT_ID=your_hcb_oauth_client_id_here
HCB_CLIENT_SECRET=your_hcb_oauth_client_secret_here
# Optional. Space-separated OAuth scopes requested at authorize time. Defaults
# in code to "read organizers:read" (what the v4 org-transactions read needs on
# a restricted app). Only set this to override if HCB changes the required
# scopes. Set to a single space to force no scope param.
# HCB_OAUTH_SCOPE=read organizers:read
NEXT_PUBLIC_HCB_DONATE_BASE=https://hcb.hackclub.com/donations/start/your_hcb_org_slug_here
SLACK_WEBHOOK_URL=your_slack_webhook_url_here
SLACK_CHANNEL=#your_slack_channel_here
SLACK_CHANNEL_ID=your_slack_channel_id_here
# Public base URL used for links in emails (no request context there).
# Local dev: http://localhost:3000. Production: https://shop.hackclub.com
NEXT_PUBLIC_API_URL=https://shop.hackclub.com
SLACK_SIGNING_SECRET=your_slack_signing_secret_here
GLOBAL_ADMINS=user_id_1,user_id_2,user_id_3
AIRTABLE_API_KEY=your_airtable_api_key_here
AIRTABLE_BASE_ID=your_airtable_base_id_here
AIRTABLE_TABLE_NAME=Projects

# Transactional email (optional — sends are a safe no-op until configured).
# EMAIL_PROVIDER is 'resend' or 'postmark'; set the matching key + a from address.
# Every recipient email carries a one-click unsubscribe link + List-Unsubscribe
# header; the link is signed with NEXTAUTH_SECRET (no extra config needed) and
# only suppresses marketing email — receipts & shipping updates always send.
EMAIL_PROVIDER=
RESEND_API_KEY=
POSTMARK_TOKEN=
EMAIL_FROM=Hack Club Shop <shop@hackclub.com>
# Where customer replies go (Reply-To header). The From identity above is for
# sending only; point replies at the monitored support inbox. Defaults to
# shop@hackclub.com if unset.
EMAIL_REPLY_TO=shop@hackclub.com
ADMIN_ORDER_EMAIL=

# Shipping / postage via Pirate Ship (runs on EasyPost). Optional — without a key,
# fulfillment falls back to pasting a tracking number bought manually in Pirate Ship.
EASYPOST_API_KEY=
# Fallback parcel weight (oz) when a variant has no weightOz set. Defaults to 6.
SHIP_DEFAULT_PARCEL_OZ=6
SHIP_FROM_NAME=Hack Club Shop
SHIP_FROM_COMPANY=
SHIP_FROM_STREET1=
SHIP_FROM_STREET2=
SHIP_FROM_CITY=
SHIP_FROM_STATE=
SHIP_FROM_ZIP=
SHIP_FROM_COUNTRY=US
SHIP_FROM_PHONE=